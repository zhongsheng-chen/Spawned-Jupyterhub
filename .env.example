# ==================================================
# JupyterHub Environment Configuration
# ==================================================
#
# Instructions:
# 1. Copy this file to `.env` for local development
# 2. Fill in your actual values
# 3. Never commit `.env` files with real secrets to version control
# 4. For production, use CI/CD injection or secrets management
#
# ==================================================

# ==================================================
# Global Settings
# ==================================================

# Timezone used by containers and applications
# Examples: Asia/Shanghai, America/New_York, UTC
TZ=Asia/Shanghai

# Docker network for JupyterHub and user containers
# This network should be created before running docker-compose
DOCKER_NETWORK_NAME=jupyterhub-network

# Default notebook image for users
# Examples:
#   - zhongsheng/base-notebook:python-3.10
#   - jupyter/base-notebook:python-3.10
#   - quay.io/jupyter/base-notebook:python-3.10
#   - jupyter/base-notebook:latest
#   - quay.io/jupyter/base-notebook:latest
DOCKER_NOTEBOOK_IMAGE=zhongsheng/base-notebook:python-3.10

# Working directory inside user containers
# This is where user files will be stored/persisted
DOCKER_NOTEBOOK_DIR=/home/jovyan/work

# ==================================================
# Resource Limits
# ==================================================

# CPU and memory limits for each user notebook container
# Uncomment and set values if you want to enforce resource limits
# DOCKER_NOTEBOOK_CPU_LIMIT=2          # CPU cores (e.g., 0.5, 1, 2)
# DOCKER_NOTEBOOK_MEMORY_LIMIT=4G      # Memory (e.g., 512M, 2G, 4G)

# GPU support for user notebooks (if available)
# Set to "all" for all GPUs, or specific GPU IDs (e.g., "0,1")
# DOCKER_NOTEBOOK_GPU=false

# ==================================================
# Database Connection Settings (DISABLED by default)
#
# NOTE:
# - All database configurations are commented out by default
# - Uncomment only when direct database access is needed
# - For production, it's recommended to inject these via CI/CD
#   or use a secrets management service
# ==================================================

# --------------------------------------------------
# GAUSSDB Connection Settings
# --------------------------------------------------
# GAUSSDB_HOST=<localhost>        # Database hostname or IP
# GAUSSDB_PORT=<5432>             # Database port (default: 5432)
# GAUSSDB_DBNAME=<db_name>        # Database name
# GAUSSDB_USER=<user>             # Username
# GAUSSDB_PASSWORD=<password>     # Password

# --------------------------------------------------
# VERTICA Connection Settings
# --------------------------------------------------
# VERTICA_HOST=<localhost>        # Database hostname or IP
# VERTICA_PORT=<5433>             # Database port (default: 5433)
# VERTICA_DBNAME=<db_name>        # Database name
# VERTICA_USER=<user>             # Username
# VERTICA_PASSWORD=<password>     # Password

# --------------------------------------------------
# ODPS Connection Settings (Alibaba Cloud MaxCompute)
# --------------------------------------------------
# ODPS_ACCESS_ID="<your-access-id>"     # ODPS AccessKey ID
# ODPS_ACCESS_KEY="<your-access-key>"   # ODPS AccessKey Secret
# ODPS_PROJECT="<your-project>"         # ODPS project name
# ODPS_ENDPOINT="<your-endpoint>"       # ODPS endpoint URL

# ==================================================
# Notes:
# ==================================================
# 1. For local development: cp .env.example .env
# 2. Fill in your actual values in .env
# 3. For production: use environment-specific files
#    e.g., .env.prod, .env.staging
# 4. Never commit sensitive data to version control
# 5. Use `docker-compose --env-file .env up` to specify env file
# ==================================================